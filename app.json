{
  "expo": {
    "name": "SakthiCare",
    "slug": "sakthicare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sakthicare",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sakthicare.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "processing"],
        "NSMicrophoneUsageDescription": "Used for alarm sounds"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A0A2E"
      },
      "package": "com.sakthicare.app",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#9B59B6",
          "sounds": ["./assets/sounds/alarm.mp3"]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A0A2E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "851cf94b-74b1-41e5-b4e4-9a611e90f253"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/851cf94b-74b1-41e5-b4e4-9a611e90f253"
    }
  }
}